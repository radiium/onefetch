		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.54.1",
		"svelte-check": "^4.4.5",
		"typescript": "^5.9.3",
